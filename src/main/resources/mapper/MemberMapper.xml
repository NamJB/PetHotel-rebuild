<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pethotel.mapper.UserMapper">
   
   <insert id = "postMember">     
     insert into member(user_id,pwd) 
     values (#{user_id},#{pwd})
   </insert>
   
   <select id = "loginUser" resultType = "com.pethotel.dto.MemberDto">
      select * from member 
      where user_id = #{user_id} 
      and pwd = #{pwd}
   </select>
</mapper>