<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pethotel.mapper.BoardMapper">
   
   <select id="getBoardList" resultType="com.pethotel.dto.BoardListResponseDto">
    select  
       b.board_id as boardId,
       b.writer_id as writerId,
       b.view_count as viewCount,
       b.title,
       b.board_type as boardType,
       b.created_at as createdAt,
       m.nickname as nickName
    from board b
    left join member m on m.member_id = writer_id
    WHERE del_yn = 'N'
    <choose>
        <when test="boardType == 'ALL'">
            AND board_type IN ('B01', 'B02', 'B03')
        </when>
        
        <when test="boardType == 'B01'">
            AND board_type = 'B01'
        </when>
        
        <otherwise>
            AND board_type IN ('B01', #{boardType})
        </otherwise>
    </choose>
    
    ORDER BY (CASE WHEN board_type = 'B01' THEN 0 ELSE 1 END), board_id DESC
   </select>
   
   <insert id = "postWrite" parameterType = "com.pethotel.dto.BoardFormRequestDto">
      insert into 
      board(title,content,writer_id,board_type,secret_yn)
      values(#{title},#{content},#{writerId},#{boardType},#{secretYN})    
   </insert>
   
   <select id = "detailBoard" resultType = "com.pethotel.dto.BoardDetailResponseDto">
      select
         b.board_id as boardId,
         b.title,
         b.content,
         b.board_type as boardType,
         b.secret_yn  as secretYN ,
         b.created_at as createdAt,
         b.view_count as viewCount,
         m.nickname as nickName
      from board b 
      left join member m on m.member_id = b.writer_id
      where b.board_id = #{boardId}         
   </select>
   
   <update id = "postUpdate">
      update board set
         title = #{title},
         content = #{content},
         board_type = #{boardType},
         secret_yn = #{secretYN}
      where board_id = #{boardId}
   </update>
   
   <select id = "getWriterId" resultType = "Integer">
      select 
         writer_id
      from board 
      where board_id = #{boardId} 
   </select>
   
   <update id = "boardDelete">
      update board set
         del_yn = "Y"
      where board_id = #{boardId}
   </update>
   
   <select id = "getMyBoard" resultType  = "com.pethotel.dto.BoardListResponseDto">
      select
         b.board_id as boardId,
         b.view_count as viewCount,
         b.title,
         b.board_type as boardType,
         b.created_at as createdAt,
         m.nickname as nickName
      from board b
      inner join  member m on m.member_id = b.writer_id
      where m.member_id = #{memberId}
         
   </select>
   
   
   
