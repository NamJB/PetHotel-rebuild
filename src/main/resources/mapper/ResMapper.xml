<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pethotel.mapper.ResMapper">
   
   <insert id="save" parameterType="com.pethotel.dto.ResDto"
        useGeneratedKeys="true" keyProperty="res_id">
    insert into reservation(member_id, check_in, check_out)
    values(#{member_id}, #{check_in}, #{check_out})
  </insert>
   
   <insert id = "savePet">
      insert into 
      reservation_pet(res_id,name,age,size,content)
      values
      <foreach collection = "list" item = "pet" separator = ",">
         (#{pet.res_id},#{pet.name},#{pet.age},#{pet.size},#{pet.content})
      </foreach>      
   </insert>
   
   
   <resultMap id = "resMap" type = "com.pethotel.dto.ResDto">
      <id property = "res_id" column= "res_id"/>
         <result property = "member_id" column = "member_id"/>
         <result property = "check_in" column = "check_in"/>
         <result property = "check_out" column = "check_out"/>
         <result property = "status" column = "status"/>
         <result property = "created_at" column = "created_at"/>
           
      <collection property = "pets" ofType = "com.pethotel.dto.PetInfoDto">
         <id property = "pet_id" column = "pet_id"/>
            <result property = "name" column = "name"/>
            <result property = "age" column = "age"/>
            <result property = "size" column = "size"/>
            <result property = "content" column = "content"/>         
      </collection>
   </resultMap>
   
   <select id = "getMyres" resultMap = "resMap">
      select 
      r.res_id,
      r.member_id,
      r.check_in,
      r.check_out,
      r.status,
      r.created_at,
      p.pet_id,
      p.name,
      p.age,
      p.size,
      p.content
      from reservation r inner join reservation_pet p on p.res_id = r.res_id
      where r.res_id = #{res_id}     
   </select>
   
   <select id = "resDelete">
      update 
      reservation set
      status ="예약 취소"
      where res_id = #{res_id} 
   </select>
   
   <select id = "getResById">
      select 
      * 
      from
      reservation
      where id = #{id}
   </select>
   
   <delete id = "petDelete">
     delete 
     from 
     reservation_pet 
     where res_id = #{id}
   </delete>
   
   <update id = "postUpdate">
      update reservation 
      set 
      check_in = #{check_in},
      check_out = #{check_out}
      where id = #{id}      
   </update>
   
   
</mapper>