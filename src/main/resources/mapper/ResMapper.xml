<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pethotel.mapper.ResMapper">
   
   <insert id="save" parameterType="com.pethotel.dto.ResDto"
        useGeneratedKeys="true" keyProperty="res_id">
    insert into reservation(member_id, check_in, check_out)
    values(#{member_id}, #{check_in}, #{check_out})
  </insert>
   
   <insert id = "savePet">
      insert into 
      reservation_pet(res_id,name,age,size,content)
      values
      <foreach collection = "list" item = "pet" separator = ",">
         (#{pet.res_id},#{pet.name},#{pet.age},#{pet.size},#{pet.content})
      </foreach>      
   </insert>
   
   <select id = "resPet" resultType = "com.pethotel.dto.PetInfoDto">
       select 
       dog_type,
       count
       from reservation_pet
       where res_id = #{id}      
   </select>
   
   <select id = "getView">
      select 
      * 
      from 
      reservation
      where id = #{id} 
   </select>
   
   <select id = "resDelete">
      update 
      reservation set
      status ="예약 취소"
      where id = #{id} 
   </select>
   
   <select id = "getResMember_id" resultType = "int">
      select
      member_id from
      reservation
      where id = #{id}
   </select>
   
   <select id = "getResById">
      select 
      * 
      from
      reservation
      where id = #{id}
   </select>
   
   <delete id = "petDelete">
     delete 
     from 
     reservation_pet 
     where res_id = #{id}
   </delete>
   
   <update id = "postUpdate">
      update reservation 
      set 
      check_in = #{check_in},
      check_out = #{check_out}
      where id = #{id}      
   </update>
   
   
</mapper>