<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.ResMapper">
   <insert id = "save">
      insert into 
      reservation(member_id,check_in,check_out,small_cnt,medium_cnt,large_cnt)
      values (#{member_id},#{check_in},#{check_out},#{small_cnt},#{medium_cnt},#{large_cnt})
   </insert>
</mapper>