<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pethotel.mapper.ResMapper">
   
   <insert id = "resSave" useGeneratedKeys="true" keyProperty="resId">
      insert into reservation
         (member_id,check_in,check_out)
      values(#{memberId},#{checkIn},#{checkOut})   
   </insert>
   
  <insert id = "petSave">
     insert into reservation_pet
        (res_id,pet_id)
     values
      <foreach collection = "petIds" item = "petId" separator = ",">
         (#{resId},#{petId})
      </foreach>
  </insert>
  <!-- 예약 생성일이랑 펫 생성일 구분해야함 -->
  <resultMap id = "resDetailMap" type = "com.pethotel.dto.ResDetailResponseDto" >
     <id property = "resId" column ="res_id"/>
     <result property  = "checkIn" column = "check_in"/>
     <result property = "checkOut" column = "check_out"/>
     <result property = "status" column = "status"/>
     <result property = "memberId" column = "member_id"/>
     <result property = "nickName" column = "nickname"/>
     
     <collection property = "pets" ofType = "com.pethotel.dto.PetListResponseDto">
        <id property = "petId" column = "pet_id"/>
        <result property ="name" column = "name"/>
        <result property ="age" column = "age"/>
        <result property ="type" column = "type"/>
        <result property ="gender" column = "gender"/>
        <result property ="note" column = "note"/>
        <result property ="weight" column = "weight"/>
        <result property ="createdAt" column = "created_at"/>
     </collection>
  </resultMap>
  
  
  <select id = "resDetail" resultMap = "resDetailMap">
     select 
        r.*,
        p.*,
        m.nickname
     from reservation r 
     inner join reservation_pet rp on r.res_id = rp.res_id
     inner join pet p on rp.pet_id = p.pet_id
     inner join member m on r.member_id = m.member_id
     where r.res_id = #{resId}
  </select>
  
  <select id = "getMyReservationList" resultType = "com.pethotel.dto.ResListResponseDto">
      select                                           
         r.res_id as resId,
         r.check_in as checkIn,
         r.check_out as checkOut,
         r.status,
         r.created_at as createdAt,
         m.nickname as nickName
      from reservation r inner join member m on r.member_id = m.member_id
      where r.member_id = #{memberId}
      order by r.res_id  desc       
   </select>
   
   <update id = "cancelReservation">
      update 
         reservation set
         status = "예약 취소"
         where res_id = #{resId}
   </update>
 
</mapper>