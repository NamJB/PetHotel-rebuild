<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pethotel.mapper.UserMapper">
   
   <insert id = "postMember">     
     insert into member(userid,pwd,username,nickname,phone) 
     values (#{userid},#{pwd},#{username},#{nickname},#{phone})
   </insert>
   
   <select id = "loginUser" resultType = "com.pethotel.dto.MemberResponseDto">
     select userid,username,phone,member_id,nickname from member 
     where userid = #{userid} 
     and pwd = #{pwd}
   </select>
  
   <select id = "checkUserid" resultType = "int">
      select count(*) 
      from member 
      where userid = #{userid}
   </select>
   
</mapper>